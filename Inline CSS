<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Travel Card</title>

  <style>

    /* Universal Selector */
    * {
      font-size: 16px;
    }

    /* Element Selectors */
    body {
      background-color: lavender;
    }

    h1 {
      color: darkred;
    }

    h2 {
      color: teal;
    }

    p {
      color: dimgray;
    }

    /* Class Selector */
    .travel-info {
      color: darkgreen;
      font-weight: bold;
    }

    /* ID Selector */
    #travel-card {
      background-color: honeydew;
    }

  </style>
</head>
<body>

  <h1>My Travel Card</h1>

  <!-- Inline CSS -->
  <p style="color: tomato;">Welcome to my travel adventure page!</p>

  <div id="travel-card">

    <h2>About My Trip</h2>
    <p class="travel-info">Destination: Japan</p>
    <p class="travel-info">Favourite City: Kyoto</p>
    <p class="travel-info">Favourite Activity: Exploring Temples</p>
    <p class="travel-info">Favourite Food: Sushi</p>

  </div>

  <h2>Travel Highlights</h2>
  <p>Visited beautiful gardens.</p>
  <p>Experienced local culture.</p>
  <p>Tried traditional Japanese cuisine.</p>

</body>
</html>
