<!DOCTYPE html>
<html>
<head>
  <title>My Sports Profile</title>

  <style>
    body {
      background-color: lightblue;
      font-family: Arial, sans-serif;
    }

    /* Box Model Example */
    .sports-card {
      background-color: white;
      color: darkslategray;
      width: 280px;          /* Content Width */
      padding: 25px;         /* Space inside the box */
      border: 4px solid navy; /* Border around the box */
      margin: 30px auto;     /* Space outside the box */
      border-radius: 12px;
    }

    .sport-name {
      color: navy;
      font-size: 24px;
    }

    .detail {
      color: darkslategray;
    }

    .fun-fact {
      color: darkorange;
      font-style: italic;
    }
  </style>
</head>
<body>

  <div class="sports-card">
    <h2 class="sport-name">Football</h2>

    <p class="detail">Players: 11 per team</p>

    <p class="detail">Popular In: Europe and South America</p>

    <p class="detail">Equipment: Ball and Goal Posts</p>

    <p class="fun-fact">
      Fun Fact: Football is the most popular sport in the world!
    </p>
  </div>

</body>
</html>
