<!DOCTYPE html>
<html>
<head>
  <title>Magic Balloon Animation</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: skyblue;
      text-align: center;
      padding-top: 50px;
    }

    h1 {
      color: navy;
    }

    .balloon {
      width: 80px;
      height: 100px;
      background-color: crimson;
      border-radius: 50%;
      margin: 50px auto;
      animation: floatUp 3s infinite alternate;
    }

    @keyframes floatUp {
      from {
        transform: translateY(0px);
        background-color: crimson;
      }

      to {
        transform: translateY(-120px);
        background-color: gold;
      }
    }

    .message {
      color: darkblue;
      font-size: 18px;
      font-weight: bold;
    }
  </style>

</head>
<body>

  <h1>Magic Balloon Animation</h1>

  <div class="balloon"></div>

  <p class="message">Watch the balloon float up and change color!</p>

</body>
</html>
