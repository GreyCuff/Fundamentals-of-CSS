<!DOCTYPE html>
<html>
<head>
  <title>School Notice Board</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: lightyellow;
      padding: 80px 30px 30px 30px;
      min-height: 1200px;
    }

    h1, h2 {
      color: darkorange;
    }

    /* Fixed Position */
    .top-banner {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background-color: darkorange;
      color: white;
      padding: 15px;
      text-align: center;
    }

    /* Relative Position */
    .announcement {
      position: relative;
      left: 40px;
      background-color: gold;
      padding: 10px;
      margin: 15px 0;
    }

    /* Absolute Position */
    .notice-card {
      position: relative;
      background-color: white;
      border: 3px solid darkorange;
      padding: 20px;
      margin-top: 20px;
    }

    .new-badge {
      position: absolute;
      top: 10px;
      right: 10px;
      background-color: forestgreen;
      color: white;
      padding: 5px 10px;
    }

    /* Sticky Position */
    .section-title {
      position: sticky;
      top: 55px;
      background-color: darkorange;
      color: white;
      padding: 10px;
      margin-top: 20px;
    }

    .item {
      background-color: white;
      border: 2px solid darkorange;
      padding: 10px;
      margin: 8px 0;
    }
  </style>
</head>
<body>

  <div class="top-banner">
    School Notice Board
  </div>

  <h1>Welcome Students!</h1>

  <h2>Relative Positioning</h2>
  <div class="announcement">
    Annual Sports Day Next Week!
  </div>

  <h2>Absolute Positioning</h2>
  <div class="notice-card">
    <p>Science Exhibition Registration Open</p>
    <div class="new-badge">NEW</div>
  </div>

  <h2>Sticky Positioning</h2>
  <p>Scroll down to see the sticky heading remain visible.</p>

  <div class="section-title">
    Upcoming Events
  </div>

  <div class="item">Art Competition</div>
  <div class="item">Debate Contest</div>
  <div class="item">Quiz Championship</div>
  <div class="item">Music Festival</div>
  <div class="item">Drama Performance</div>
  <div class="item">Coding Workshop</div>
  <div class="item">Science Fair</div>
  <div class="item">Sports Tournament</div>

</body>
</html>
